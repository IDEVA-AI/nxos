{
  "name": "nxos",
  "version": "0.2.0",
  "description": "Universal multi-agent orchestration framework — create AI squads that work together",
  "type": "module",
  "bin": {
    "nxos": "bin/nxos.js"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "version": "node -e \"require('fs').writeFileSync('templates/_nxos/.nxos-version', require('./package.json').version + '\\n')\" && git add templates/_nxos/.nxos-version"
  },
  "keywords": [
    "ai-agents",
    "multi-agent",
    "orchestration",
    "squads",
    "nxos"
  ],
  "author": "Renato Asse (https://github.com/renatoasse)",
  "homepage": "https://github.com/renatoasse/nxos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renatoasse/nxos.git"
  },
  "bugs": {
    "url": "https://github.com/renatoasse/nxos/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "agents/",
    "skills/",
    "templates/"
  ],
  "dependencies": {
    "@inquirer/checkbox": "^5.1.0",
    "@inquirer/input": "^5.0.0",
    "@inquirer/select": "^5.1.0"
  }
}
